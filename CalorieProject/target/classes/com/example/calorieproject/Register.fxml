<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.calorieproject.RegisterController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            style="-fx-background:#0f172a;">

    <content>

        <VBox alignment="CENTER"
              spacing="25"
              style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b, #334155);">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- APP TITLE -->
            <VBox alignment="CENTER" spacing="8">

                <Label text="Create Account"
                       style="-fx-font-size:34px;
                              -fx-font-weight:bold;
                              -fx-text-fill:white;"/>

                <Label text="Join the NutriTrack platform"
                       style="-fx-font-size:14px;
                              -fx-text-fill:#cbd5e1;"/>

            </VBox>

            <!-- REGISTER CARD -->
            <VBox alignment="CENTER"
                  spacing="18"
                  maxWidth="430"
                  prefWidth="430"
                  style="-fx-background-color: rgba(255,255,255,0.08);
                         -fx-background-radius:24;
                         -fx-padding:35;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 18, 0.2, 0, 6);
                         -fx-border-color: rgba(255,255,255,0.12);
                         -fx-border-radius:24;">

                <!-- FULL NAME -->
                <VBox spacing="6" prefWidth="360">

                    <Label text="Full Name"
                           style="-fx-text-fill:#e2e8f0;
                                  -fx-font-size:13px;
                                  -fx-font-weight:bold;"/>

                    <TextField fx:id="nameField"
                               promptText="Enter your full name"
                               prefHeight="42"
                               style="-fx-background-color:#f8fafc;
                                      -fx-background-radius:12;
                                      -fx-font-size:14px;
                                      -fx-padding:0 12 0 12;"/>

                </VBox>

                <!-- USERNAME -->
                <VBox spacing="6" prefWidth="360">

                    <Label text="Username"
                           style="-fx-text-fill:#e2e8f0;
                                  -fx-font-size:13px;
                                  -fx-font-weight:bold;"/>

                    <TextField fx:id="userField"
                               promptText="Choose a username"
                               prefHeight="42"
                               style="-fx-background-color:#f8fafc;
                                      -fx-background-radius:12;
                                      -fx-font-size:14px;
                                      -fx-padding:0 12 0 12;"/>

                </VBox>

                <!-- PASSWORD -->
                <VBox spacing="6" prefWidth="360">

                    <Label text="Password"
                           style="-fx-text-fill:#e2e8f0;
                                  -fx-font-size:13px;
                                  -fx-font-weight:bold;"/>

                    <PasswordField fx:id="passField"
                                   promptText="Create a password"
                                   prefHeight="42"
                                   style="-fx-background-color:#f8fafc;
                                          -fx-background-radius:12;
                                          -fx-font-size:14px;
                                          -fx-padding:0 12 0 12;"/>

                </VBox>

                <!-- CONFIRM PASSWORD -->
                <VBox spacing="6" prefWidth="360">

                    <Label text="Confirm Password"
                           style="-fx-text-fill:#e2e8f0;
                                  -fx-font-size:13px;
                                  -fx-font-weight:bold;"/>

                    <PasswordField fx:id="confirmPassField"
                                   promptText="Re-enter password"
                                   prefHeight="42"
                                   style="-fx-background-color:#f8fafc;
                                          -fx-background-radius:12;
                                          -fx-font-size:14px;
                                          -fx-padding:0 12 0 12;"/>

                </VBox>

                <!-- BUTTONS -->
                <HBox alignment="CENTER" spacing="14">

                    <padding>
                        <Insets top="10" right="0" bottom="0" left="0"/>
                    </padding>

                    <Button text="Create Account"
                            onAction="#handleCreateAccount"
                            prefWidth="170"
                            prefHeight="42"
                            style="-fx-background-color:#3b82f6;
                   -fx-text-fill:white;
                   -fx-font-size:14px;
                   -fx-font-weight:bold;
                   -fx-background-radius:14;
                   -fx-cursor:hand;"/>

                    <Button text="Back to Login"
                            onAction="#switchToLogin"
                            prefWidth="170"
                            prefHeight="42"
                            style="-fx-background-color:#334155;
                   -fx-text-fill:white;
                   -fx-font-size:14px;
                   -fx-font-weight:bold;
                   -fx-background-radius:14;
                   -fx-cursor:hand;"/>

                </HBox>

                <!-- STATUS -->
                <Label fx:id="statusLabel"
                       wrapText="true"
                       maxWidth="340"
                       style="-fx-text-fill:#fca5a5;
                              -fx-font-size:13px;
                              -fx-font-weight:bold;"/>

            </VBox>

        </VBox>

    </content>

</ScrollPane>