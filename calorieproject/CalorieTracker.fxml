<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="20.0" prefWidth="450.0" prefHeight="500.0"
      xmlns="http://javafx.com" xmlns:fx="http://javafx.com"
      fx:controller="com.example.calorieproject.CalorieTrackerController">
    <padding>
        <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
    </padding>

    <!-- Welcome Headline Header -->
    <VBox alignment="CENTER" spacing="5.0">
        <Label fx:id="welcomeLabel" text="Welcome, User!" style="-fx-font-size: 18px; -fx-font-weight: bold;" textFill="#2c3e50"/>
        <HBox alignment="CENTER" spacing="10.0">
            <Label text="Total Calories Today:" style="-fx-font-size: 14px;"/>
            <Label fx:id="totalCaloriesLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;" textFill="#27ae60"/>
        </HBox>
    </VBox>

    <!-- Interactive Data Entry Form Fields -->
    <VBox spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8;">
        <Label text="Log Food or Meal" style="-fx-font-weight: bold;"/>
        <TextField fx:id="foodNameField" promptText="Item name (e.g., Apple, Chicken Salad)"/>
        <HBox spacing="10.0">
            <TextField fx:id="calorieField" promptText="Calories" prefWidth="120.0"/>
            <Button text="Add Food Item" onAction="#handleAddFood" style="-fx-background-color: #3498db; -fx-text-fill: white;" prefWidth="120.0"/>
            <Button text="Add Meal" onAction="#handleAddMeal" style="-fx-background-color: #e67e22; -fx-text-fill: white;" prefWidth="120.0"/>
        </HBox>
    </VBox>

    <!-- Daily Log Display Center -->
    <VBox spacing="10.0" VBox.vgrow="ALWAYS">
        <Label text="Today's Consumption Log" style="-fx-font-weight: bold;"/>
        <ListView fx:id="logListView" VBox.vgrow="ALWAYS"/>
    </VBox>

    <Button text="Log Out" onAction="#handleLogout" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" prefWidth="100.0"/>
</VBox>
