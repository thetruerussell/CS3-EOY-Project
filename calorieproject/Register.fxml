<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.calorieproject.RegisterController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Create New Account" />

    <TextField fx:id="nameField" promptText="Full Name" />
    <TextField fx:id="userField" promptText="Username" />
    <PasswordField fx:id="passField" promptText="Password" />
    <PasswordField fx:id="confirmPassField" promptText="Confirm Password" />

    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#handleCreateAccount" text="Create Account" />
        <Button onAction="#switchToLogin" text="Back to Login" />
    </HBox>

    <Label fx:id="statusLabel" textFill="RED" wrapText="true" />
</VBox>
